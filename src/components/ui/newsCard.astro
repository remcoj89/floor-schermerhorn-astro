---
interface Props {
  title: string;
  description: string;
  date: string;
  link: string;
  image: string;
}

const { title, description, date, link, image } = Astro.props;
---

<article class="card">
  <div class="card-image">
    <img src={`${image}?auto=format&fit=crop&w=600&q=80`} alt={title} loading="lazy" />
    <div class="date-badge">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      {date}
    </div>
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
  </div>
  <div class="card-footer">
    <a href={link} class="read-more">
      Lees meer
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arrow-icon">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--clr-card);
    border: 1px solid color-mix(in srgb, var(--clr-border) 50%, transparent);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .card:hover .card-image img {
    transform: scale(1.05);
  }

  .date-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: color-mix(in srgb, var(--clr-bg) 90%, transparent);
    backdrop-filter: blur(4px);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--fs-sm);
    font-weight: 500;
    box-shadow: var(--shadow-sm);
    color: var(--clr-fg);
  }

  .date-badge svg {
    color: var(--clr-primary);
    flex-shrink: 0;
  }

  .card-body {
    flex: 1;
    padding: 1.5rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-title {
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--clr-fg);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    font-size: var(--fs-base);
    color: var(--clr-muted-fg);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
  }

  .card-footer {
    padding: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--clr-border) 50%, transparent);
    margin-top: 1.5rem;
  }

  .read-more {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font-weight: 600;
    color: var(--clr-fg);
    padding: 0.625rem 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .read-more:hover {
    background-color: color-mix(in srgb, var(--clr-primary) 10%, transparent);
    color: var(--clr-primary);
  }

  .arrow-icon {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .read-more:hover .arrow-icon {
    transform: translateX(4px);
  }
</style>
