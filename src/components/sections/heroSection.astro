---
import content from '../../data/content.json';

const { badge, title, subtitle, date, location, image, ctas } = content.hero;
---

<section id="over" class="hero">
  <div class="hero-bg">
    <img
      src={image.src}
      alt={image.alt}
      class="hero-img"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-gradient"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="ping-wrapper" aria-hidden="true">
          <span class="ping"></span>
          <span class="ping-dot"></span>
        </span>
        {badge}
      </div>

      <h1 class="hero-title">{title}</h1>
      <p class="hero-sub">{subtitle}</p>

      <div class="hero-meta">
        <div class="meta-chip">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <span>{date}</span>
        </div>
        <div class="meta-chip">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span>{location}</span>
        </div>
      </div>

      <div class="hero-ctas">
        <a href={ctas.primary.href} class="btn btn-primary">{ctas.primary.label}</a>
        <a href={ctas.secondary.href} class="btn btn-outline">{ctas.secondary.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    align-items: center;
    display: flex;
    justify-content: center;
    min-height: 90dvh;
    overflow: hidden;
    position: relative;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background-color: hsl(30, 20%, 15%, 0.4);
    mix-blend-mode: multiply;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    /* background: linear-gradient(to top, var(--clr-bg) 0%, transparent 20%); */
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: 5rem 3rem;
  }

  .hero-inner {
    max-width: 56rem;
    margin-inline: auto;
    animation: fadeInUp 0.7s ease both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    background-color: rgba(245, 196, 0, 0.2);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(245, 196, 0, 0.3);
    color: #fff;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .ping-wrapper {
    position: relative;
    display: flex;
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  .ping {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background-color: var(--clr-primary);
    opacity: 0.75;
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .ping-dot {
    position: relative;
    display: inline-flex;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background-color: var(--clr-primary);
  }

  .hero-title {
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: var(--fs-xl);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    margin-inline: auto;
    max-width: none;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 480px) {
    .hero-meta {
      flex-direction: row;
    }
  }

  .meta-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-xl);
    color: #fff;
    font-size: var(--fs-lg);
    font-weight: 500;
  }

  .meta-chip svg {
    color: var(--clr-primary);
    flex-shrink: 0;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .hero-ctas {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--ff-body);
    font-size: var(--fs-lg);
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      background-color var(--transition-fast);
    white-space: nowrap;
    width: 100%;
  }

  @media (min-width: 480px) {
    .btn {
      width: auto;
    }
  }

  .btn-primary {
    background: var(--clr-primary);
    color: var(--clr-primary-fg);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245, 196, 0, 0.4);
  }

  .btn-outline {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }
</style>
