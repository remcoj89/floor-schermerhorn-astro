---
import content from '../../data/content.json';

const { title, namen } = content.vriendenVanDeFloor;
---

<section id="vrienden-van-de-floor" class="section">
  <div class="container">
    <div class="inner animate-on-scroll">
      <h2>{title}</h2>
      <p>{namen}</p>
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: var(--space-section);
  }

  .inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  h2 {
    color: var(--clr-fg);
  }

  p {
    max-width: none;
    margin-inline: auto;
    font-size: var(--fs-base);
    color: var(--clr-muted-fg);
    line-height: 1.8;
    text-align: center;
  }
</style>
