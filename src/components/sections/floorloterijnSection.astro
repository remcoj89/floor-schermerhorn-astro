---
import content from '../../data/content.json';

const { title, paragraphs, badge } = content.floorloterij;
---

<section id="floorloterij" class="section">
  <div class="container">
    <div class="inner animate-on-scroll">

      <div class="icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"></path>
          <path d="M13 5v2"></path><path d="M13 17v2"></path><path d="M13 11v2"></path>
        </svg>
      </div>

      <h2>{title}</h2>

      {paragraphs.map((p) => <p>{p}</p>)}

      <div class="price-badge">{badge}</div>

    </div>
  </div>
</section>

<style>
  .section {
    padding-block: var(--space-section);
    background-color: var(--clr-secondary);
  }

  .inner {
    max-width: 48rem;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5rem;
    height: 5rem;
    background: var(--clr-card);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
    color: var(--clr-primary);
  }

  h2 {
    color: var(--clr-fg);
  }

  p {
    font-size: var(--fs-lg);
    color: color-mix(in srgb, var(--clr-secondary-fg) 80%, transparent);
    margin-inline: auto;
  }

  .price-badge {
    display: inline-block;
    background: var(--clr-primary);
    color: var(--clr-primary-fg);
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: var(--fs-2xl);
    padding: 1rem 2rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    transform: rotate(2deg);
  }
</style>
