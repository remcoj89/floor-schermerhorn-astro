---
import BaseLayout from '../layouts/baseLayout.astro';
import HeroSection from '../components/sections/heroSection.astro';
import FloormarktSection from '../components/sections/floormarktSection.astro';
import FloorloterijnSection from '../components/sections/floorloterijnSection.astro';
import TruckershowSection from '../components/sections/truckershowSection.astro';
import ProgrammaSection from '../components/sections/programmaSection.astro';
import VrijwilligersSection from '../components/sections/vrijwilligersSection.astro';
import SponsorenSection from '../components/sections/sponsorenSection.astro';
import VriendenVanDeFloorSection from '../components/sections/vriendenVanDeFloorSection.astro';
---

<BaseLayout
  title="Floor Feestdagen - Het jaarlijkse dorpsfeest van Schermerhorn"
  description="12 & 13 september 2026 | Schermerhorn | Gratis entree. Het jaarlijkse dorpsfeest met Floormarkt, Truckershow, live muziek en meer!"
>
  <HeroSection />
  <FloormarktSection />
  <FloorloterijnSection />
  <TruckershowSection />
  <ProgrammaSection />
  <VrijwilligersSection />
  <SponsorenSection />
  <VriendenVanDeFloorSection />
</BaseLayout>
