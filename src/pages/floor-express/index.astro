---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/baseLayout.astro';
import NewsCard from '../../components/ui/newsCard.astro';

const articles = await getCollection('floor-express');
const sorted = articles.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout
  title="Floor-Express - Nieuwsbrief Floor Schermerhorn"
  description="Blijf op de hoogte van het laatste nieuws, de programma-updates en alle verhalen rondom het Floor Nazoemerspektakel in Schermerhorn."
>

  <section class="hero-section">
    <div class="container hero-inner">
      <div class="badge">Nieuwsbrief</div>
      <h1>Floor-Express</h1>
      <p class="sub">De nieuwsbrief van Floor Schermerhorn</p>
      <p class="desc">
        Blijf op de hoogte van het laatste nieuws, de programma-updates en alle verhalen rondom het Floor Nazoemerspektakel in Schermerhorn.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ul class="articles-grid" role="list">
        {sorted.map((article) => (
          <li>
            <NewsCard
              title={article.data.title}
              description={article.data.description}
              date={article.data.date}
              link={`/floor-express/${article.slug}`}
              image={article.data.image}
            />
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-section {
    background-color: var(--clr-secondary);
    padding-block: 5rem;
    border-bottom: 1px solid var(--clr-border);
  }

  .hero-inner {
    text-align: center;
    max-width: 48rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .badge {
    display: inline-block;
    background: var(--clr-primary);
    color: var(--clr-primary-fg);
    padding: 0.375rem 1rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    font-size: var(--fs-3xl);
    color: var(--clr-fg);
    margin-top: 0.5rem;
  }

  .sub {
    font-size: var(--fs-xl);
    font-weight: 500;
    color: color-mix(in srgb, var(--clr-secondary-fg) 80%, transparent);
    max-width: none;
  }

  .desc {
    font-size: var(--fs-lg);
    color: color-mix(in srgb, var(--clr-secondary-fg) 70%, transparent);
    margin-inline: auto;
  }

  .section {
    padding-block: var(--space-section);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
