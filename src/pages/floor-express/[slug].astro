---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/baseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('floor-express');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const { title, description, date, image } = article.data;

const shareUrl = encodeURIComponent(Astro.url.href);
const shareTitle = encodeURIComponent(title);
---

<BaseLayout title={`${title} - Floor-Express`} description={description} image={image}>

  <div class="hero-img-wrap">
    <img
      src={`${image}?auto=format&fit=crop&w=1920&q=80`}
      alt={title}
      class="hero-img"
      loading="eager"
    />
    <div class="hero-gradient"></div>
  </div>

  <div class="container article-container">
    <article class="article-card">

      <a href="/floor-express" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Terug naar alle edities
      </a>

      <div class="article-meta">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <span>{date}</span>
      </div>

      <h1>{title}</h1>

      <div class="article-content">
        <Content />
      </div>

      <div class="share-bar">
        <span class="share-label">Deel dit artikel:</span>
        <div class="share-buttons">
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-btn-facebook"
            aria-label="Deel op Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a
            href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-btn-whatsapp"
            aria-label="Deel via WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
          </a>
        </div>
      </div>

    </article>
  </div>

</BaseLayout>

<style>
  .hero-img-wrap {
    position: relative;
    width: 100%;
    height: clamp(15rem, 40vh, 25rem);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--clr-bg) 0%, color-mix(in srgb, var(--clr-bg) 20%, transparent) 50%, transparent 100%);
  }

  .article-container {
    position: relative;
    margin-top: -8rem;
    padding-bottom: 6rem;
    z-index: 1;
  }

  .article-card {
    max-width: 48rem;
    margin-inline: auto;
    background: var(--clr-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--clr-border);
    padding: clamp(2rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--clr-muted-fg);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition-fast);
    width: fit-content;
    margin-bottom: 0.5rem;
  }

  .back-link:hover {
    color: var(--clr-fg);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--clr-primary);
    font-weight: 600;
    font-size: var(--fs-base);
  }

  h1 {
    font-size: clamp(1.75rem, 3vw + 1rem, 3rem);
    color: var(--clr-fg);
    max-width: none;
  }

  .article-content {
    font-size: var(--fs-lg);
    color: var(--clr-muted-fg);
    line-height: 1.8;
  }

  .article-content :global(p) {
    max-width: none;
    margin-bottom: 1rem;
  }

  .share-bar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--clr-border);
    margin-top: 1rem;
  }

  @media (min-width: 480px) {
    .share-bar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .share-label {
    font-weight: 600;
    color: var(--clr-fg);
  }

  .share-buttons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--clr-border);
    color: var(--clr-fg);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .share-btn-facebook:hover {
    background: #1877F2;
    color: #fff;
    border-color: #1877F2;
  }

  .share-btn-whatsapp:hover {
    background: #25D366;
    color: #fff;
    border-color: #25D366;
  }
</style>
